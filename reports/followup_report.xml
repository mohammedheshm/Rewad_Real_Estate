<odoo>

    <record id="action_followup_report" model="ir.actions.report">
        <field name="name">Follow Up Report</field>
        <field name="model">property.followup</field>
        <field name="report_type">qweb-html</field>
        <!-- <field name="report_type">qweb-pdf</field> -->
        <field name="binding_model_id" ref="model_property_followup"/>
        <field name="binding_type">report</field>
        <field name="report_name">rewad_real_estate.followup_report_template</field>
    </record>

    <template id="followup_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">

                    <div class="page">
                        <h2 style="text-align:center;">Follow-Up Report</h2>

                        <br/>
                        <table class="table table-sm table-bordered">
                            <tr>
                                <th>Customer</th>
                                <td>
                                    <span t-field="o.lead_id.name"/>
                                </td>
                            </tr>
                            <tr>
                                <th>Mobile</th>
                                <td>
                                    <span t-field="o.lead_id.mobile"/>
                                </td>
                            </tr>
                            <tr>
                                <th>Follow Up Date</th>
                                <td>
                                    <span t-field="o.follow_up_date"/>
                                </td>
                            </tr>
                            <tr>
                                <th>Next Follow Up</th>
                                <td>
                                    <span t-field="o.next_follow_up_date"/>
                                </td>
                            </tr>
                            <tr>
                                <th>Notes</th>
                                <td>
                                    <span t-field="o.follow_up_notes"/>
                                </td>
                            </tr>
                        </table>

                    </div>

                </t>
            </t>
        </t>
    </template>

</odoo>
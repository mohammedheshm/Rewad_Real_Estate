<odoo>

    <record id="action_lead_report" model="ir.actions.report">
        <field name="name">Lead Report</field>
        <field name="model">property.lead</field>
        <field name="report_type">qweb-html</field>
        <field name="binding_model_id" ref="model_property_lead"/>
        <field name="binding_type">report</field>
        <field name="report_name">rewad_real_estate.lead_report_template</field>
    </record>


    <template id="lead_report_template">

        <t t-call="web.html_container">
            <t t-call="web.external_layout">

                <div class="page">

                    <h2 style="text-align:center;">
                        Lead Report
                    </h2>

                    <br/>

                    <table class="table table-bordered table-sm">

                        <thead>
                            <tr style="background-color:#f2f2f2;">
                                <th>Lead Code</th>
                                <th>Customer Name</th>
                                <th>Mobile</th>
                                <th>Property Type</th>
                                <th>Required Area</th>
                                <th>Budget</th>
                                <th>Status</th>
                                <th>Selected Property</th>
                            </tr>
                        </thead>

                        <tbody>

                            <tr t-foreach="docs" t-as="o">

                                <td>
                                    <span t-field="o.lead_code"/>
                                </td>

                                <td>
                                    <span t-field="o.name"/>
                                </td>

                                <td>
                                    <span t-field="o.mobile"/>
                                </td>

                                <td>
                                    <span t-field="o.property_type"/>
                                </td>

                                <td>
                                    <span t-field="o.required_area"/>
                                </td>

                                <td>
                                    <span t-field="o.budget"/>
                                </td>

                                <td>
                                    <span t-field="o.status"/>
                                </td>

                                <td>
                                    <span t-field="o.property_unit_id"/>
                                </td>

                            </tr>

                        </tbody>

                    </table>

                    <br/>

                    <div style="text-align:right;">
                        <strong>
                            Total Leads:
                            <span t-esc="len(docs)"/>
                        </strong>
                    </div>

                </div>

            </t>
        </t>

    </template>

</odoo>
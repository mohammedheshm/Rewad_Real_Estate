<odoo>

    <record id="action_property_report" model="ir.actions.report">
        <field name="name">Property Report</field>
        <field name="model">property.unit</field>
        <field name="report_type">qweb-html</field>
        <field name="binding_model_id" ref="model_property_unit"/>
        <field name="binding_type">report</field>
        <field name="report_name">rewad_real_estate.property_report_template</field>
    </record>


    <template id="property_report_template">

        <t t-call="web.html_container">
            <t t-call="web.external_layout">

                <div class="page">

                    <h2 style="text-align:center;">
                        Property Report
                    </h2>

                    <br/>

                    <table class="table table-bordered table-sm">

                        <thead>
                            <tr style="background-color:#f2f2f2;">
                                <th>Code</th>
                                <th>Type</th>
                                <th>Owner</th>
                                <th>Governorate</th>
                                <th>Address</th>
                                <th>Floor</th>
                                <th>Area</th>
                                <th>Price</th>
                                <th>Payment</th>
                                <th>Status</th>
                            </tr>
                        </thead>

                        <tbody>

                            <tr t-foreach="docs" t-as="o">

                                <td>
                                    <span t-field="o.property_code"/>
                                </td>

                                <td>
                                    <span t-field="o.property_type"/>
                                </td>

                                <td>
                                    <span t-field="o.owner_id.name"/>
                                </td>

                                <td>
                                    <span t-field="o.governorate"/>
                                </td>

                                <td>
                                    <span t-field="o.address"/>
                                </td>

                                <td>
                                    <span t-field="o.floor"/>
                                </td>

                                <td>
                                    <span t-field="o.area_size"/>
                                </td>

                                <td>
                                    <span t-field="o.price"/>
                                </td>

                                <td>
                                    <span t-field="o.payment_type"/>
                                </td>

                                <td>
                                    <span t-field="o.status"/>
                                </td>

                            </tr>

                        </tbody>

                    </table>

                    <br/>

                    <div style="text-align:right;">
                        <strong>
                            Total Properties:
                            <span t-esc="len(docs)"/>
                        </strong>
                    </div>

                </div>

            </t>
        </t>

    </template>

</odoo>
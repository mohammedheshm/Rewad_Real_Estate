<odoo>

    <!-- MODULE CATEGORY -->
    <record id="module_category_real_estate" model="ir.module.category">
        <field name="name">Real Estate Management</field>
        <field name="description">Security access control for real estate system</field>
    </record>


    <!-- ADMIN -->
    <record id="group_real_estate_admin" model="res.groups">
        <field name="name">Administration</field>
        <field name="category_id" ref="module_category_real_estate"/>
    </record>


    <!-- SALES -->
    <record id="group_real_estate_sales" model="res.groups">
        <field name="name">Sales Agent</field>
        <field name="category_id" ref="module_category_real_estate"/>
    </record>


    <!-- ACCOUNTANT -->
    <record id="group_real_estate_accountant" model="res.groups">
        <field name="name">Accountant</field>
        <field name="category_id" ref="module_category_real_estate"/>
    </record>


    <!-- RECORD RULES -->

    <!-- ADMIN: see all -->
    <record id="rule_property_admin" model="ir.rule">
        <field name="name">Admin All Properties</field>
        <field name="model_id" ref="model_property_unit"/>
        <field name="groups" eval="[(4, ref('group_real_estate_admin'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
    </record>


    <!-- SALES: available only -->
    <record id="rule_property_sales" model="ir.rule">
        <field name="name">Sales Available Properties</field>
        <field name="model_id" ref="model_property_unit"/>
        <field name="groups" eval="[(4, ref('group_real_estate_sales'))]"/>
        <field name="domain_force">[('status','=','available')]</field>
    </record>


    <!-- ACCOUNTANT: sold only -->
    <record id="rule_property_accountant" model="ir.rule">
        <field name="name">Accountant Sold Properties</field>
        <field name="model_id" ref="model_property_unit"/>
        <field name="groups" eval="[(4, ref('group_real_estate_accountant'))]"/>
        <field name="domain_force">[('status','=','sold')]</field>
    </record>


</odoo>

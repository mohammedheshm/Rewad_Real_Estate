<odoo>
    <!-- Tree View -->
    <record id="view_property_unit_tree" model="ir.ui.view">
        <field name="name">property.unit.tree</field>
        <field name="model">property.unit</field>
        <field name="arch" type="xml">
            <tree>
                <field name="property_code"/>
                <field name="property_type"/>
                <field name="owner_id"/>
                <field name="governorate_id"/>
                <field name="address_id"/>
                <field name="area_size"/>
                <field name="price"/>
                <field name="status"/>
            </tree>
        </field>
    </record>


    <!-- Form View -->
    <record id="view_property_unit_form" model="ir.ui.view">
        <field name="name">property.unit.form</field>
        <field name="model">property.unit</field>
        <field name="arch" type="xml">
            <form string="Property Unit">
                <header>
                    <button name="action_reserved"
                            string="Reserve"
                            type="object"
                            class="btn-warning"
                            invisible="status != 'available'"/>

                    <button name="action_sold"
                            string="Sell"
                            type="object"
                            class="btn-success"
                            invisible="status != 'reserved'"/>

                    <button name="action_available"
                            string="Reset"
                            type="object"
                            class="btn-secondary"
                            invisible="status == 'available'"/>

                    <button name="open_price_wizard"
                            type="object"
                            string="Search by Price"
                            class="oe_highlight"
                            icon="fa-search"/>

                    <field name="status"
                           widget="statusbar"
                           statusbar_visible="available,reserved,sold"/>

                </header>
                <sheet>
                    <widget name="web_ribbon"
                            title="SOLD"
                            bg_color="bg-danger"
                            invisible="status != 'sold'"/>
                    <group>
                        <group>
                            <field name="property_code"/>
                            <field name="property_type"/>
                            <field name="owner_id"/>
                        </group>

                        <group>
                            <field name="price"/>
                            <field name="payment_type"/>
                            <field name="area_size"/>
                            <field name="floor"/>
                        </group>

                        <group string="Property Financials">

                            <group>
                                <field name="owner_price"/>
                                <field name="commission"/>
                            </group>

                            <group>
                                <field name="paid_to_owner"/>
                                <field name="paid_to_owner_date"/>
                                <field name="remaining_to_owner" readonly="1"/>
                                <field name="profit"/>
                            </group>

                        </group>

                    </group>

                    <notebook>

                        <page string="Location">

                            <group>
                                <field name="governorate_id"/>
                                <field name="address_id"/>
                            </group>

                        </page>

                        <page string="Notes">

                            <field name="notes"/>

                        </page>

                        <page string="Image">

                            <field name="image" widget="image"/>

                        </page>

                    </notebook>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>


    <!-- Search View -->
    <record id="view_property_unit_search" model="ir.ui.view">
        <field name="name">property.unit.search</field>
        <field name="model">property.unit</field>
        <field name="arch" type="xml">

            <search>

                <!-- Search Fields -->

                <field name="property_code"/>
                <field name="owner_id"/>
                <field name="price"/>

                <separator/>

                <!-- Filters -->

                <filter
                        string="Available"
                        name="available"
                        domain="[('status','=','available')]"/>

                <filter
                        string="Reserved"
                        name="reserved"
                        domain="[('status','=','reserved')]"/>

                <filter
                        string="Sold"
                        name="sold"
                        domain="[('status','=','sold')]"/>

                <separator/>

                <filter
                        string="Apartment"
                        name="apartment"
                        domain="[('property_type','=','apartment')]"/>

                <filter
                        string="Villa"
                        name="villa"
                        domain="[('property_type','=','villa')]"/>

                <filter
                        string="Land"
                        name="land"
                        domain="[('property_type','=','land')]"/>

                <filter
                        string="Office"
                        name="office"
                        domain="[('property_type','=','office')]"/>

                <filter
                        string="Shop"
                        name="shop"
                        domain="[('property_type','=','shop')]"/>

                <filter
                        string="Owner"
                        name="owner_id"
                        domain="[('property_type','=','owner_id')]"/>

                <filter string="Price under 1M"
                        name="under_1m"
                        domain="[('price','&lt;',1000000)]"/>

                <filter string="Price between 1M - 2M"
                        name="between_1_2"
                        domain="[('price','&gt;=',1000000),('price','&lt;=',2000000)]"/>

                <filter string="Price Above 2M"
                        name="above_2m"
                        domain="[('price','&gt;',2000000)]"/>

                <separator/>

                <!-- Group By -->

                <group expand="0" string="Group By">

                    <filter
                            string="Property Type"
                            name="group_property_type"
                            context="{'group_by':'property_type'}"/>

                    <filter
                            string="Owner"
                            name="group_owner"
                            context="{'group_by':'owner_id'}"/>
                    <filter
                            string="Status"
                            name="group_status"
                            context="{'group_by':'status'}"/>


                    <filter
                            string="Governorate"
                            name="group_governorate"
                            context="{'group_by':'governorate_id'}"/>


                    <filter
                            string="Address"
                            name="group_address"
                            context="{'group_by':'address_id'}"/>

                    <filter
                            string="Price"
                            name="group_price"
                            context="{'group_by':'price'}"/>


                </group>

            </search>

        </field>
    </record>


    <!--Search Server  Action -->

    <record id="action_search_by_price_wizard" model="ir.actions.server">
        <field name="name">Search by Price</field>

        <!-- ⭐ مهم جدًا -->
        <field name="model_id" ref="model_property_unit"/>
        <field name="binding_model_id" ref="model_property_unit"/>
        <field name="binding_type">action</field>

        <field name="state">code</field>

        <field name="code">
            action = {
            'type': 'ir.actions.act_window',
            'name': 'Search by Price',
            'res_model': 'property.price.search.wizard',
            'view_mode': 'form',
            'target': 'new',
            }
        </field>
    </record>

    <!-- Action -->

    <record id="action_property_unit" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">property.unit</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

    <menuitem
            id="menu_property_unit"
            name="Properties"
            parent="all_property_unit"
            action="action_property_unit"
            sequence="1"/>
</odoo>
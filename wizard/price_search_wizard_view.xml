<odoo>

    <record id="view_price_search_wizard_form" model="ir.ui.view">
        <field name="name">property.price.search.wizard.form</field>
        <field name="model">property.price.search.wizard</field>
        <field name="arch" type="xml">
            <form string="Search by Price">

                <group>
                    <field name="price_from"/>
                    <field name="price_to"/>
                </group>

                <footer>
                    <button name="action_search"
                            type="object"
                            string="Search"
                            class="btn-primary"/>

                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>

            </form>
        </field>
    </record>

</odoo>